<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KTelemetry Demo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnInfoEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send_info_event"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnDebugEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send_debug_event"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnWarnEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send_warn_event"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnErrorEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send_error_event"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnCustomEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send_custom_event"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnTriggerCrash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/trigger_crash"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#FF0000" />

    <Button
        android:id="@+id/btnFlushEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/flush_events"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text=""
        android:textSize="14sp" />

</LinearLayout>

